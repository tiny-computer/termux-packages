+func setTermuxSelfExe(sysattr *syscall.ProcAttr, selfExe string) {
+    for i, v := range sysattr.Env {
+	if strings.HasPrefix(v, "TERMUX_EXEC__PROC_SELF_EXE=") {
+		// Stdout.WriteString("FOUND EXISTING ENV: " + v)
+		sysattr.Env[i] = "TERMUX_EXEC__PROC_SELF_EXE=" + selfExe
+		// Stdout.WriteString("NEW ENV: " + sysattr.Env[i])
+		return
+	}
+    }
+    sysattr.Env = append(sysattr.Env, "TERMUX_EXEC__PROC_SELF_EXE=" + selfExe)
+}
+
+// cleanPath is a simplified, POSIX-only version of filepath.Clean
+func cleanPath(path string) string {
+	if path == "" {
+		return "."
+	}
+
+	isAbs := path[0] == '/'
+	segments := splitPaths(path)
+	var out []string
+
+	for _, s := range segments {
+		if s == "" || s == "." {
+			continue
+		}
+		if s == ".." {
+			if len(out) > 0 && out[len(out)-1] != ".." {
+				out = out[:len(out)-1]
+			} else if !isAbs {
+				out = append(out, "..")
+			}
+			continue
+		}
+		out = append(out, s)
+	}
+
+	if len(out) == 0 {
+		if isAbs {
+			return "/"
+		}
+		return "."
+	}
+
+	joined := ""
+	if isAbs {
+		joined = "/"
+	}
+
+	for i, s := range out {
+		if i > 0 {
+			joined += "/"
+		}
+		joined += s
+	}
+	return joined
+}
+
+// splitPath splits a path by / without using strings package
+func splitPaths(path string) []string {
+	var parts []string
+	start := 0
+	for i := 0; i < len(path); i++ {
+		if path[i] == '/' {
+			parts = append(parts, path[start:i])
+			start = i + 1
+		}
+	}
+	parts = append(parts, path[start:])
+	return parts
+}
+
+// absPath is a manual implementation of filepath.Abs for POSIX
+// to be used internally within the os package.
+func absPath(path string) string {
+	if path == "" {
+		return ""
+	}
+
+	var res string
+	if path[0] == '/' {
+		res = path
+	} else {
+		wd, err := Getwd() // Available within package os
+		if err != nil {
+			return ""
+		}
+		res = wd + "/" + path
+	}
+
+	return cleanPath(res)
+}
+
+func rewriteExecutablePath(origPath string) string {
+	if strings.HasPrefix(origPath, "/bin/") {
+		return "/data/data/com.termux/files/usr" + origPath
+	} else if strings.HasPrefix(origPath, "/usr/bin/") {
+		return "/data/data/com.termux/files" + origPath
+	} else {
+		return absPath(origPath)
+	}
+}
